<div class="text-center">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Already a member? Enter Clubhouse", new_session_path(resource_name),
          class: "block text-purple-400 hover:text-purple-300 transition duration-200 text-sm font-medium" %><br />
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Request Membership", new_registration_path(resource_name),
          class: "block text-blue-400 hover:text-blue-300 transition duration-200 text-sm font-medium" %><br />
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your secret code?", new_password_path(resource_name),
          class: "block text-gray-400 hover:text-gray-300 transition duration-200 text-sm" %><br />
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "No invitation received?", new_confirmation_path(resource_name),
          class: "block text-gray-400 hover:text-gray-300 transition duration-200 text-sm" %><br />
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Account locked?", new_unlock_path(resource_name),
          class: "block text-gray-400 hover:text-gray-300 transition duration-200 text-sm" %><br />
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Secret entrance with #{OmniAuth::Utils.camelize(provider)}",
            omniauth_authorize_path(resource_name, provider),
            data: { turbo: false },
            class: "w-full mt-4 py-2 px-4 border border-gray-600 rounded-lg text-gray-300 hover:bg-gray-700 transition duration-200 text-sm" %><br />
    <% end %>
  <% end %>
</div>
