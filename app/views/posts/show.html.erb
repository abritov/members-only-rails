<!-- app/views/posts/show.html.erb -->

<% content_for :title, @post.title %>

<div class="min-h-screen bg-gradient-to-br from-gray-900 to-black py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">

    <!-- Notice (Styled) -->
    <% if notice %>
      <div class="bg-green-900/50 border border-green-700 rounded-lg p-4 text-green-200 mb-8 shadow-md">
        <%= notice %>
      </div>
    <% end %>

    <!-- Single Post View Container - Applies similar styling as index posts -->
    <div class="bg-gray-800 rounded-2xl shadow-xl overflow-hidden border border-gray-700 mb-8">
      <!-- Post Header (similar to index) -->
      <div class="bg-gradient-to-r from-purple-900/50 via-blue-900/50 to-gray-900/50 p-4 border-b border-gray-700">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="w-9 h-9 bg-gradient-to-r from-purple-600 to-blue-600 rounded-full flex items-center justify-center">
              <span class="text-white font-bold text-sm">
                <%= @post.user.email[0].upcase %>
              </span>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-300">Anonymous Member</p>
              <p class="text-xs text-gray-500">Posted <%= time_ago_in_words(@post.created_at) %> ago</p>
            </div>
          </div>
          <span class="text-xs text-gray-400 bg-gray-700 px-2 py-1 rounded-full">
            #<%= @post.id %>
          </span>
        </div>
      </div>

      <!-- Post Content - Wraps the render @post partial -->
      <div class="p-6">
        <h3 class="text-3xl font-bold text-gray-100 mb-4"><%= @post.title %></h3>
        <p class="text-gray-300 leading-relaxed text-lg mb-6"><%= @post.body %></p>
        <%# If your _post.html.erb partial generates its own full content block,
            you might remove the h3 and p tags above and just leave render @post %>
        <%# <%= render @post %>
      </div>


      <!-- Post Actions - Styled -->
      <div class="px-6 py-4 bg-gray-700/50 border-t border-gray-700 flex flex-col sm:flex-row justify-between items-center space-y-3 sm:space-y-0 sm:space-x-4">
        <div class="flex space-x-4">
          <%= link_to "Edit Post", edit_post_path(@post),
                class: "inline-flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-lg transition duration-200 text-sm shadow-md",
                data: { "unpoly" => true } %>
          <%= link_to "Back to Feed", posts_path,
                class: "inline-flex items-center px-4 py-2 bg-gray-600 hover:bg-gray-500 text-gray-200 rounded-lg transition duration-200 text-sm shadow-md",
                data: { "unpoly" => true } %>
        </div>

        <%= button_to "Delete Post", @post, method: :delete,
              data: { confirm: "Are you sure you want to delete this post?" },
              class: "px-4 py-2 bg-red-700 hover:bg-red-800 text-white font-medium rounded-lg transition duration-200 text-sm shadow-md" %>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="max-w-4xl mx-auto mt-8 text-center">
    <p class="text-xs text-gray-600">© 2025 Members Only Clubhouse • Where anonymity meets exclusivity</p>
  </div>
</div>
